# ── Credentials & Secrets ─────────────────────────────────────────
confidentials/*
!confidentials/.env.template
.env
*.env
outlook_token.json

# ── Database & Data ───────────────────────────────────────────────
data/chroma_db/*
data/raw_web/*
data/raw_email/*
data/logs/*
data/registry/
data/output/

# Any backup/variant copy of the vector database under a different
# name (e.g. a "_corrupted_backup" or "_old" copy someone makes before
# a fix) -- data/chroma_db/* above only matches that one exact folder
# name, so a real ~55MB database backup once slipped through under a
# different name and got committed to git history. Deliberately
# "chroma_db_*" (with the underscore), not "chroma_db*" -- matching the
# bare "chroma_db*" would also match the real data/chroma_db/ directory
# itself, and once a directory is excluded this way, a later "!" cannot
# re-include a file inside it (confirmed directly: this broke the
# existing "!data/chroma_db/.gitkeep" exception below when tried) --
# so this pattern only catches name VARIANTS, never the original.
data/chroma_db_*/

# Same defensive net for any other ad hoc "*backup*" folder anyone
# creates directly under data/ for any reason.
data/*backup*/

# ── Processed Files (ingested documents) ──────────────────────────
data/processed/*

# ── Watched Folder (drop zone — not committed) ────────────────────
data/watched_folder/*

# ── Project Master (real file stays local) ────────────────────────
data/project_master/*
!data/project_master/.gitkeep

# ── Auto-update staging (local, transient -- code zips + org-wide ──
# setting values in plain text; the latter can be real API keys, so
# this must never be committed, not even by accident via `git add -A`)
data/pending_update/*
data/pending_settings/*

# ── Keep folder structure via .gitkeep ────────────────────────────
!data/chroma_db/.gitkeep
!data/raw_web/.gitkeep
!data/raw_email/.gitkeep
!data/logs/.gitkeep
!data/processed/.gitkeep
!data/watched_folder/.gitkeep

# ── Keep web sources ──────────────────────────────────────────────
!data/web_sources/
!data/web_sources/sources.csv

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environment ───────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Logs ──────────────────────────────────────────────────────────
*.log

# ── PyCharm ───────────────────────────────────────────────────────
.idea/
*.iml

# ── VS Code ───────────────────────────────────────────────────────
.vscode/

# ── Claude Code (personal per-machine config stays local) ─────────
.claude/settings.local.json

# ── Windows ───────────────────────────────────────────────────────
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Mac ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride